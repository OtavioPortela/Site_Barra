# =============================================================
# Variáveis de Ambiente — Barra Confecções
# Copie este arquivo para .env e preencha os valores
# =============================================================

# ─── OBRIGATÓRIAS (a app não inicia sem estas) ──────────────

# Chave secreta do Django — gere uma aleatória em produção:
# python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=django-insecure-dev-key-change-in-production-123456789

# Hosts permitidos (separados por vírgula)
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Banco de dados PostgreSQL
DATABASE_URL=postgres://usuario:senha@host:5432/nome_do_banco
# OU use as variáveis individuais abaixo (Railway injeta DATABASE_URL automaticamente):
# DATABASE_NAME=barra_confeccoes
# DATABASE_USER=postgres
# DATABASE_PASSWORD=postgres
# DATABASE_HOST=db
# DATABASE_PORT=5432

# ─── OPCIONAIS (funcionalidades específicas) ─────────────────

# Modo de debug — FALSE em produção
DEBUG=False

# Superusuário criado automaticamente no primeiro deploy
SUPERUSER_EMAIL=admin@barraconfeccoes.com
SUPERUSER_PASSWORD=admin123

# Z-API WhatsApp — necessário para envio de mensagens
# Obtenha em: app.z-api.io → sua instância → Credenciais
# Sem isso: envio de WhatsApp retorna erro 500
ZAPI_INSTANCE_ID=
ZAPI_TOKEN=
ZAPI_CLIENT_TOKEN=

# Sentry — monitoramento de erros em produção
# Obtenha em: sentry.io → New Project → Django → DSN
# Sem isso: erros não são rastreados remotamente (apenas logs locais)
SENTRY_DSN=

# Railway — domínio público para URLs de mídia no WhatsApp
# Injetado automaticamente pelo Railway; não precisa definir manualmente
RAILWAY_PUBLIC_DOMAIN=
