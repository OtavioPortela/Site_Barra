# Django Settings
SECRET_KEY=django-insecure-dev-key-change-in-production-123456789
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Database
DATABASE_NAME=barra_confeccoes
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_HOST=db
DATABASE_PORT=5432

# Superuser
SUPERUSER_EMAIL=admin@barraconfeccoes.com
SUPERUSER_PASSWORD=admin123



# Z-API WhatsApp Config
# Documentação: https://developer.z-api.io
# Obtenha as credenciais em: app.z-api.io → sua instância → Credenciais
ZAPI_INSTANCE_ID=
ZAPI_TOKEN=
ZAPI_CLIENT_TOKEN=   # Security token (aba Segurança na instância)

# Sentry — Monitoramento de erros em produção
# Obtenha em: https://sentry.io → New Project → Django → DSN
# Deixe vazio em desenvolvimento (Sentry só ativa se SENTRY_DSN estiver preenchido)
SENTRY_DSN=
